@using Microsoft.AspNetCore.Mvc.Rendering
@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    ViewData["Subtitle"] = "Something went wrong while processing your request.";

    var homeLink = new TagBuilder("a");
    homeLink.AddCssClass("btn btn-outline-secondary");
    homeLink.Attributes["href"] = Url.Action("Index", "Home", new { area = "" })!;
    homeLink.InnerHtml.Append("Back to dashboard");

    ViewData["HeaderActions"] = homeLink;
}

<partial name="_PageHeader" />

<div class="card mb-3">
    <div class="card-body">
        <div class="alert alert-danger mb-3">
            We couldn't complete the request. Please try again, or contact support if the problem persists.
        </div>
        @if (Model.ShowRequestId)
        {
            <div class="text-muted small">Request ID: <code>@Model.RequestId</code></div>
        }
    </div>
</div>
