<!DOCTYPE html>
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string NavClass(string controllerName, string actionName = "")
    {
        if (!controller.Equals(controllerName, StringComparison.OrdinalIgnoreCase))
        {
            return string.Empty;
        }

        if (string.IsNullOrWhiteSpace(actionName))
        {
            return "active fw-semibold";
        }

        return action.Equals(actionName, StringComparison.OrdinalIgnoreCase)
            ? "active fw-semibold"
            : string.Empty;
    }
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tenderizer</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Tenderizer.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-3">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Tenderizer</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link @NavClass("Home", "Index")" asp-area="" asp-controller="Home" asp-action="Index" aria-current="@(NavClass("Home", "Index") != string.Empty ? "page" : null)">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @NavClass("Tenders")" asp-area="" asp-controller="Tenders" asp-action="Index" aria-current="@(NavClass("Tenders") != string.Empty ? "page" : null)">Tenders</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @NavClass("Home", "Privacy")" asp-area="" asp-controller="Home" asp-action="Privacy" aria-current="@(NavClass("Home", "Privacy") != string.Empty ? "page" : null)">Privacy</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top mt-3">
        <div class="container py-2 text-muted small">
            &copy; 2025 - Tenderizer - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" integrity="sha384-QJ9N3mW+0j3g7kE8uPlO0m8yF9ckw+I+4VfK3A5jW1+G5rjwJc5nqT8M1d0bq9pr" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
