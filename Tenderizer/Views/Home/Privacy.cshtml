@{
    ViewData["Title"] = "Privacy";
    ViewData["Subtitle"] = "How Tenderizer handles access and data.";
}

<partial name="_PageHeader" />

<div class="card mb-3">
    <div class="card-body">
        <h3>Overview</h3>
        <p class="mb-3">Tenderizer is an internal tender tracking tool. Access is limited to authorized users.</p>

        <h3>Data we store</h3>
        <p class="mb-3">We store tender records, client names, statuses, closing dates, and account identifiers required to manage ownership.</p>

        <h3>Use of data</h3>
        <p class="mb-3">Data is used to track tenders, assign owners, and provide an audit trail of changes.</p>

        <h3>Retention</h3>
        <p class="mb-3">Data is retained according to your organization's policy. Contact your administrator for specifics.</p>

        <h3>Questions</h3>
        <p class="mb-0">Contact your system administrator for access or privacy questions.</p>
    </div>
</div>
