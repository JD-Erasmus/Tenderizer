@using Tenderizer.ViewModels
@using Tenderizer.Views.Home
@model TenderSectionVm

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>@Model.Title</strong>
        <span class="text-muted small">@Model.Items.Count</span>
    </div>

    <div class="card-body p-0">
        @{
            var tableId = Model.Title
                .ToLowerInvariant()
                .Replace(" ", "-")
                .Replace("(", string.Empty)
                .Replace(")", string.Empty);
            var tableModel = new TenderTableVm
            {
                TableId = $"{tableId}-table",
                Items = Model.Items,
                EmptyMessage = "No items.",
                EnableSearch = false,
                EnablePaging = false,
                EnableInfo = false,
                EnableLengthChange = false,
                PageLength = 5,
                DefaultOrderColumn = Model.Title == "History" ? "updatedAt" : "closingAtUtc",
                DefaultOrderDirection = Model.Title == "History" ? "desc" : "asc",
                SearchPlaceholder = "Search tenders",
            };
        }
        <partial name="_TenderTable" model="tableModel" />
    </div>
</div>
