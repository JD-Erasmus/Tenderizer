@using Tenderizer.Models
@using Tenderizer.ViewModels
@model TenderListVm

@{
    ViewData["Title"] = "Tenders";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    ViewData["Subtitle"] = $"{Model.TotalCount} total";

    var createLink = new TagBuilder("a");
    createLink.AddCssClass("btn btn-primary");
    createLink.Attributes["href"] = Url.Action("Create")!;
    createLink.InnerHtml.Append("New");
    ViewData["HeaderActions"] = createLink;

    var tableModel = new TenderTableVm
    {
        TableId = "tenders-table",
        Items = Model.Items,
        EmptyMessage = "No tenders yet.",
        EnableSearch = true,
        EnablePaging = true,
        EnableInfo = true,
        EnableLengthChange = true,
        PageLength = 10,
        DefaultOrderColumn = "closingAtUtc",
        DefaultOrderDirection = "asc",
        SearchPlaceholder = "Search tenders",
    };
}

<partial name="_PageHeader" />

<div class="d-flex justify-content-between align-items-center mb-2">
    <div class="d-flex align-items-center gap-2 flex-grow-1">
        <select class="form-select form-select-sm w-auto"
                data-datatable-target="tenders-table"
                data-datatable-column="status"
                data-datatable-exact="true">
            <option value="">All statuses</option>
            @foreach (var option in Html.GetEnumSelectList<TenderStatus>())
            {
                <option value="@option.Text">@option.Text</option>
            }
        </select>

        <div class="form-check mb-0">
            <input class="form-check-input"
                   type="checkbox"
                   id="mineOnly"
                   data-datatable-target="tenders-table"
                   data-datatable-column="ownerUserId"
                   data-datatable-exact="true"
                   data-datatable-value="@currentUserId" />
            <label class="form-check-label small" for="mineOnly">Mine only</label>
        </div>

        <button type="button" class="btn btn-sm btn-outline-secondary" data-datatable-clear="tenders-table">Clear filters</button>
    </div>
</div>

<partial name="_TenderTable" model="tableModel" />
