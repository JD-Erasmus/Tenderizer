@using Tenderizer.ViewModels
@using Microsoft.AspNetCore.Html
@using Microsoft.AspNetCore.Mvc.Rendering
@model IReadOnlyList<TenderListItemVm>

@{
    ViewData["Title"] = "Tenders";
    var query = ViewData["Query"]?.ToString() ?? string.Empty;
    var totalCount = ViewData["TotalCount"] as int? ?? Model.Count;
    ViewData["Subtitle"] = string.IsNullOrWhiteSpace(query)
        ? $"{totalCount} total"
        : $"{Model.Count} shown of {totalCount} total";

    var searchForm = new TagBuilder("form");
    searchForm.Attributes["method"] = "get";
    searchForm.Attributes["action"] = Url.Action("Index")!;
    searchForm.AddCssClass("d-flex align-items-center gap-2 w-100");

    var search = new TagBuilder("input");
    search.AddCssClass("form-control form-control-sm w-50");
    search.Attributes["type"] = "search";
    search.Attributes["name"] = "q";
    search.Attributes["placeholder"] = "Search by name or client.";
    if (!string.IsNullOrWhiteSpace(query))
    {
        search.Attributes["value"] = query;
    }
    searchForm.InnerHtml.AppendHtml(search);

    if (!string.IsNullOrWhiteSpace(query))
    {
        var clearLink = new TagBuilder("a");
        clearLink.AddCssClass("btn btn-sm btn-outline-secondary");
        clearLink.Attributes["href"] = Url.Action("Index")!;
        clearLink.InnerHtml.Append("Clear");
        searchForm.InnerHtml.AppendHtml(clearLink);
    }

    var createLink = new TagBuilder("a");
    createLink.AddCssClass("btn btn-sm btn-primary");
    createLink.Attributes["href"] = Url.Action("Create")!;
    createLink.InnerHtml.Append("New");

    ViewData["CommandLeft"] = searchForm;
    ViewData["CommandRight"] = createLink;

    var emptyMessage = string.IsNullOrWhiteSpace(query)
        ? "No tenders yet."
        : "No tenders match your search.";
}

<partial name="_PageHeader" />
<partial name="_CommandBar" />

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Client</th>
                <th>Status</th>
                <th>Closing (UTC)</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-muted small">@emptyMessage</td>
                </tr>
            }
            else
            {
                @foreach (var t in Model)
                {
                    <tr>
                        <td>@t.Name</td>
                        <td>@t.Client</td>
                        <td><partial name="_TenderStatusBadge" model="t.Status" /></td>
                        <td>@t.ClosingAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@t.Id">View</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@t.Id">Edit</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
