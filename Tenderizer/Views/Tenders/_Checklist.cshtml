@using Tenderizer.ViewModels
@model TenderDetailsVm

@if (Model.CanViewChecklist)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-0">Checklist</h2>
                    <div class="text-muted small">Checklist items, lock state, and document upload links.</div>
                </div>
                <a class="btn btn-sm btn-outline-secondary" asp-controller="TenderDocuments" asp-action="Index" asp-route-tenderId="@Model.Id">Manage Documents</a>
            </div>

            <div class="mb-3">
                <form method="post"
                      asp-action="AddChecklistItem"
                      asp-route-id="@Model.Id"
                      class="row g-2 align-items-end"
                      data-checklist-ajax-form="true">
                    @Html.AntiForgeryToken()
                    <div class="col-md-4">
                        <label class="form-label">Title</label>
                        <input name="Title" class="form-control" maxlength="200" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Description</label>
                        <input name="Description" class="form-control" maxlength="1000" />
                    </div>
                    <div class="col-md-2">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" name="Required" value="true" id="required-@Model.Id" />
                            <label class="form-check-label" for="required-@Model.Id">Required</label>
                        </div>
                    </div>
                    <div class="col-md-1 text-end">
                        <button type="submit" class="btn btn-primary btn-sm">Add</button>
                    </div>
                </form>
            </div>

            @if (Model.ChecklistItems.Count == 0)
            {
                <div class="alert alert-secondary mb-0">No checklist items yet.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Status</th>
                                <th>Lock</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ChecklistItems)
                            {
                                <tr>
                                    <td>
                                        <form method="post"
                                              asp-action="UpdateChecklistItem"
                                              asp-route-id="@Model.Id"
                                              asp-route-checklistItemId="@item.Id"
                                               class="row g-2"
                                               data-checklist-ajax-form="true">
                                            @Html.AntiForgeryToken()
                                            <div class="col-12">
                                                <input class="form-control form-control-sm mb-1" name="Title" value="@item.Title" maxlength="200" />
                                            </div>
                                            <div class="col-12">
                                                <input class="form-control form-control-sm mb-1" name="Description" value="@item.Description" maxlength="1000" />
                                            </div>
                                            <div class="col-12">
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="checkbox" name="Required" value="true" @(item.Required ? "checked" : null) id="required-@Model.Id-@item.Id" />
                                                    <label class="form-check-label" for="required-@Model.Id-@item.Id">Required</label>
                                                </div>
                                                <button type="submit" class="btn btn-sm btn-outline-secondary ms-2">Save</button>
                                            </div>
                                        </form>
                                    </td>
                                    <td>
                                        @if (item.IsCompleted)
                                        {
                                            <span class="badge text-bg-success">Completed</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">Open</span>
                                        }
                                        @if (item.Required)
                                        {
                                            <div class="text-muted small mt-1">Required</div>
                                        }
                                            @if (item.UploadedTenderDocumentId.HasValue)
                                        {
                                            <div class="text-muted small mt-1">Linked to upload</div>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.LockedByUserId))
                                        {
                                            <div>@item.LockedByUserId</div>
                                            <div class="text-muted small">Expires @item.LockExpiresAtUtc?.ToString("yyyy-MM-dd HH:mm") UTC</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Unlocked</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            <form method="post"
                                                  asp-action="AcquireChecklistLock"
                                                  asp-route-id="@Model.Id"
                                                  asp-route-checklistItemId="@item.Id"
                                                  class="d-inline"
                                                  data-checklist-ajax-form="true">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Lock</button>
                                            </form>
                                            <form method="post"
                                                  asp-action="ReleaseChecklistLock"
                                                  asp-route-id="@Model.Id"
                                                  asp-route-checklistItemId="@item.Id"
                                                  class="d-inline"
                                                  data-checklist-ajax-form="true">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-secondary">Unlock</button>
                                            </form>
                                            <form method="post"
                                                  asp-action="MarkChecklistItemCompleted"
                                                  asp-route-id="@Model.Id"
                                                  asp-route-checklistItemId="@item.Id"
                                                  class="d-inline"
                                                  data-checklist-ajax-form="true">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="tenderDocumentId" value="" />
                                                <button type="submit" class="btn btn-sm btn-outline-success">Mark Complete</button>
                                            </form>
                                            <form method="post"
                                                  asp-action="RemoveChecklistItem"
                                                  asp-route-id="@Model.Id"
                                                  asp-route-checklistItemId="@item.Id"
                                                  class="d-inline"
                                                  data-checklist-ajax-form="true">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                            </form>
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-controller="TenderDocuments"
                                               asp-action="Index"
                                               asp-route-tenderId="@Model.Id"
                                               asp-route-checklistItemId="@item.Id">Upload</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
