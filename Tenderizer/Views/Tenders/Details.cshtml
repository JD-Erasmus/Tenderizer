@using Tenderizer.ViewModels
@using Microsoft.AspNetCore.Mvc.Rendering
@model TenderDetailsVm

@{
    ViewData["Title"] = Model.Name;
    ViewData["Subtitle"] = $"Closing {Model.ClosingAtUtc:yyyy-MM-dd HH:mm} UTC";

    var editLink = new TagBuilder("a");
    editLink.AddCssClass("btn btn-primary");
    editLink.Attributes["href"] = Url.Action("Edit", new { id = Model.Id })!;
    editLink.InnerHtml.Append("Edit");

    var documentsLink = new TagBuilder("a");
    documentsLink.AddCssClass("btn btn-outline-secondary");
    documentsLink.Attributes["href"] = Url.Action("Index", "TenderDocuments", new { tenderId = Model.Id })!;
    documentsLink.InnerHtml.Append("Documents");

    var isAdmin = User.IsInRole("Admin");
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canEdit = isAdmin || string.Equals(userId, Model.OwnerUserId, StringComparison.Ordinal);

    if (canEdit && !isAdmin)
    {
        var actions = new HtmlContentBuilder().AppendHtml(documentsLink).AppendHtml(editLink);
        ViewData["HeaderActions"] = actions;
    }
    else if (isAdmin)
    {
        var deleteForm = new TagBuilder("form");
        deleteForm.Attributes["method"] = "post";
        deleteForm.Attributes["action"] = Url.Action("DeleteConfirmed", new { id = Model.Id })!;
        deleteForm.AddCssClass("d-inline");
        deleteForm.InnerHtml.AppendHtml(Html.AntiForgeryToken());

        var deleteButton = new TagBuilder("button");
        deleteButton.Attributes["type"] = "button";
        deleteButton.Attributes["data-delete-button"] = "true";
        deleteButton.AddCssClass("btn btn-outline-danger");
        deleteButton.InnerHtml.Append("Delete");

        deleteForm.InnerHtml.AppendHtml(deleteButton);

        var actions = new HtmlContentBuilder().AppendHtml(documentsLink).AppendHtml(editLink).AppendHtml(deleteForm);
        ViewData["HeaderActions"] = actions;
    }
}

<partial name="_PageHeader" />

@if (canEdit)
{
    <div class="card mb-3">
        <div class="card-body">
            <form method="post" asp-action="UpdateStatus" asp-route-id="@Model.Id" class="d-flex align-items-end gap-2">
                @Html.AntiForgeryToken()
                <div class="flex-grow-1">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<TenderStatus>()"></select>
                    <div class="form-text">Update the tender state without opening the full edit form.</div>
                </div>
                <button type="submit" class="btn btn-outline-secondary">Save Status</button>
            </form>
        </div>
    </div>
}

<partial name="_Checklist" model="Model" />

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Reference</dt>
            <dd class="col-sm-9">@Model.ReferenceNumber</dd>

            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Model.Client</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><partial name="_TenderStatusBadge" model="Model.Status" /></dd>

            <dt class="col-sm-3">Closing (UTC)</dt>
            <dd class="col-sm-9">@Model.ClosingAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</dd>

            <dt class="col-sm-3">Owner</dt>
            <dd class="col-sm-9">@Model.OwnerDisplayName</dd>

            <dt class="col-sm-3">Created (UTC)</dt>
            <dd class="col-sm-9">@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</dd>

            <dt class="col-sm-3">Updated (UTC)</dt>
            <dd class="col-sm-9">@Model.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</dd>
        </dl>
    </div>
</div>

@section Scripts {
    <script src="~/js/tender-workflow.js" asp-append-version="true"></script>
}
