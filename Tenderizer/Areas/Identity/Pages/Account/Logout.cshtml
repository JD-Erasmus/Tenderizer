@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<partial name="_PageHeader" />

@if (User.Identity?.IsAuthenticated ?? false)
{
    <div class="row">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="card mb-3">
                <div class="card-body">
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Log out</button>
                            <a class="btn btn-outline-secondary" asp-area="" asp-controller="Home" asp-action="Index">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-muted">You have successfully logged out.</div>
}
